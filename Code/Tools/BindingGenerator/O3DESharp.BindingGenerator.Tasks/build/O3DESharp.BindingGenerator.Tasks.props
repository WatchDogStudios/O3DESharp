<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- 
    O3DE Binding Generator Default Properties
    These can be overridden in your project file
  -->
  <PropertyGroup>
    <!-- Path to O3DE project.json or gem.json -->
    <O3DEProjectPath Condition="'$(O3DEProjectPath)' == ''">$(MSBuildProjectDirectory)\..\..\project.json</O3DEProjectPath>
    
    <!-- Path to binding configuration file -->
    <O3DEBindingConfig Condition="'$(O3DEBindingConfig)' == ''">$(MSBuildProjectDirectory)\..\..\binding_config.json</O3DEBindingConfig>
    
    <!-- Path to the binding generator executable (auto-detected if empty) -->
    <O3DEGeneratorPath Condition="'$(O3DEGeneratorPath)' == ''"></O3DEGeneratorPath>
    
    <!-- Output path for generated files -->
    <O3DEOutputPath Condition="'$(O3DEOutputPath)' == ''">$(MSBuildProjectDirectory)\..\..\Assets\Scripts</O3DEOutputPath>
    
    <!-- Enable/disable binding generation -->
    <O3DEGenerateBindings Condition="'$(O3DEGenerateBindings)' == ''">true</O3DEGenerateBindings>
    
    <!-- Enable/disable design-time generation for IntelliSense -->
    <O3DEDesignTimeGenerate Condition="'$(O3DEDesignTimeGenerate)' == ''">true</O3DEDesignTimeGenerate>
    
    <!-- Enable/disable incremental builds -->
    <O3DEIncremental Condition="'$(O3DEIncremental)' == ''">true</O3DEIncremental>
    
    <!-- Force regeneration of all bindings -->
    <O3DEForceRegen Condition="'$(O3DEForceRegen)' == ''">false</O3DEForceRegen>
    
    <!-- Enable verbose logging -->
    <O3DEVerbose Condition="'$(O3DEVerbose)' == ''">false</O3DEVerbose>
    
    <!-- Enable cleaning of generated files -->
    <O3DECleanBindings Condition="'$(O3DECleanBindings)' == ''">false</O3DECleanBindings>
  </PropertyGroup>

  <!--
    Default gems to generate bindings for (empty = all enabled gems)
    Override this in your project to specify gems:
    
    <ItemGroup>
      <O3DEGems Include="MyGem" />
      <O3DEGems Include="AnotherGem" />
    </ItemGroup>
  -->
  <ItemGroup>
    <O3DEGems Include="" />
  </ItemGroup>

</Project>
