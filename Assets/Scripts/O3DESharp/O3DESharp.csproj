<Project Sdk="Microsoft.NET.Sdk">

  <!--
    O3DESharp bindings project.

    This project compiles the C# bindings generated by the ClangSharp-based
    O3DESharp.BindingGenerator tool. The directory contains only generated
    *.g.cs files; on a fresh clone these are absent until the generator runs
    (CMake target: O3DESharp.GenerateBindings, or run the generator manually
    from Code/Tools/BindingGenerator/O3DESharp.BindingGenerator/).
  -->
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>latest</LangVersion>
    <AssemblyName>O3DESharp</AssemblyName>
    <RootNamespace>O3DE.O3DESharp</RootNamespace>
    <Version>1.0.0</Version>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- O3DE Binding Generator Configuration -->
  <PropertyGroup>
    <O3DEProjectPath>$(MSBuildProjectDirectory)\..\..\gem.json</O3DEProjectPath>
    <O3DEGenerateBindings>true</O3DEGenerateBindings>
    <O3DEDesignTimeGenerate>true</O3DEDesignTimeGenerate>
    <O3DEIncremental>true</O3DEIncremental>
  </PropertyGroup>

  <ItemGroup>
    <O3DEGems Include="O3DESharp" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\O3DE.Core\O3DE.Core.csproj">
      <Private>false</Private>
    </ProjectReference>
  </ItemGroup>

  <!-- Import O3DE Binding Generator MSBuild Task (optional) -->
  <Import Project="$(O3DEBindingGeneratorTasksPath)" Condition="Exists('$(O3DEBindingGeneratorTasksPath)')" />

</Project>
